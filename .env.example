# ─── Application ──────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database ─────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/transport_db

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_REFRESH_SECRET=change_this_to_another_long_random_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Email (SMTP) ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@quicksenddelivery.com
CONTACT_EMAIL=team@quicksenddelivery.com

# ─── Admin ────────────────────────────────────────────────
ADMIN_SECRET=change_this_to_a_strong_admin_secret

# ─── Frontend ─────────────────────────────────────────────
CLIENT_URL=http://localhost:3000

# ─── Google Maps ─────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ─── Logging ──────────────────────────────────────────────
LOG_LEVEL=info
